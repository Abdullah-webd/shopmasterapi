# Server
PORT=3000
NODE_ENV=development

# Auth
# Shared bearer token Shopmaster sends in: Authorization: Bearer <INTEGRATION_TOKEN>
INTEGRATION_TOKEN=replace-with-a-strong-random-token

# Database (SQL Server 2017+)
# Use DB_SERVER=host with DB_PORT, or DB_SERVER=host\instance with DB_PORT left blank.
DB_SERVER=your-sql-server-host
DB_INSTANCE=
DB_DATABASE=your_database
DB_USER=your_user
DB_PASSWORD=your_password
DB_PORT=1433
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000

# Idempotency
# How long to keep replaying stored responses (hours)
IDEMPOTENCY_TTL_HOURS=24

# Images
# URLs are stored in SQL Server. This folder is only for a future/optional
# local downloader that saves remote image files after the request succeeds.
IMAGE_DOWNLOAD_DIR=./storage/images
